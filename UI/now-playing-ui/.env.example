# Docker Compose defaults to /api, which Nginx proxies to the API container.
# Set this only when running the UI against a separately hosted API.
VITE_API_BASE_URL=/api
VITE_REACT_APP_NEWS_API_KEY=replace-with-news-api-key
VITE_REACT_APP_TMDB_API_KEY=replace-with-tmdb-api-key
VITE_REACT_APP_SPOTIFY_API_KEY=replace-with-spotify-api-key
