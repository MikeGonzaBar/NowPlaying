DJANGO_ENV=development
DEBUG=true
SECRET_KEY=replace-with-a-long-random-development-secret
# Development-only sample Fernet key. Generate a unique key for real environments.
API_KEY_ENCRYPTION_KEY=C3fygP72WNfaeLgDXCwPRgxSzWQctoCY7fHB3DNOZPM=
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3200
CORS_ALLOW_ALL_ORIGINS=false

POSTGRES_DB=nowplaying
POSTGRES_USER=nowplaying_user
POSTGRES_PASSWORD=nowplaying_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional. If unset, the API derives the callback URL from the incoming request.
# With the default Docker UI proxy, set the Trakt app redirect to:
# http://<ui-host>:3200/api/trakt/oauth-callback/
# If you bypass the UI proxy, set this to the exact API callback instead.
TRAKT_REDIRECT_URI=
TMDB_API_KEY=replace-with-tmdb-api-key
